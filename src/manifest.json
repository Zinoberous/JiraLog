{
  "manifest_version": 3,
  "name": "JiraLog",
  "version": "0.1.0",
  "description": "Day-focused Jira worklogs in the browser – capture and manage quickly.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "JiraLog"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": ["storage"],
  "host_permissions": ["https://*.atlassian.net/*"]
}
